<Window
    x:Class="ModernImageViewer.Desktop.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ModernImageViewer.Desktop.ViewModels"
    Title="灵简图片助手"
    Icon="/Assets/LingJianImageAssistant.ico"
    Width="1180"
    Height="720"
    MinWidth="640"
    MinHeight="480"
    Background="#F4F4F5"
    WindowStartupLocation="CenterScreen"
    FontFamily="Microsoft YaHei UI, Microsoft YaHei, PingFang SC, Hiragino Sans GB, Segoe UI">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BoxShadow" Value="0 1 3 0 #0C000000, 0 4 12 0 #08000000" />
    </Style>

    <Style Selector="Border.section">
      <Setter Property="Background" Value="#F9FAFB" />
      <Setter Property="BorderBrush" Value="#F3F4F6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.metric">
      <Setter Property="Background" Value="#ECFDF5" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="BoxShadow" Value="0 1 2 0 #06000000" />
    </Style>

    <Style Selector="Border.viewport">
      <Setter Property="Background" Value="#0C111D" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.listItem">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BoxShadow" Value="0 1 2 0 #06000000" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18" />
          <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ListBoxItem:pointerover Border.listItem">
      <Setter Property="Background" Value="#F9FAFB" />
      <Setter Property="BoxShadow" Value="0 2 6 0 #0C000000" />
    </Style>

    <Style Selector="ListBoxItem:selected Border.listItem">
      <Setter Property="Background" Value="#F0F9FF" />
      <Setter Property="BoxShadow" Value="0 2 8 0 #10000000, inset 0 0 0 1.5 #3B82F6" />
    </Style>

    <Style Selector="Border.toolbarSurface">
      <Setter Property="Background" Value="#F9FAFB" />
      <Setter Property="BorderBrush" Value="#F3F4F6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style Selector="Border.quickSettings">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="BoxShadow" Value="0 12 40 0 #1C000000, 0 2 6 0 #0A000000" />
    </Style>

    <Style Selector="Border.quickSettingsSurface">
      <Setter Property="Background" Value="#F9FAFB" />
      <Setter Property="BorderBrush" Value="#F3F4F6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.aboutHero">
      <Setter Property="Background" Value="#ECFDF5" />
      <Setter Property="BorderBrush" Value="#00000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="Border.separator">
      <Setter Property="Background" Value="#F3F4F6" />
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="0,4,0,4" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="Height" Value="30" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.toolbar">
      <Setter Property="Height" Value="32" />
      <Setter Property="MinWidth" Value="58" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="Button.flyoutAction">
      <Setter Property="Height" Value="36" />
      <Setter Property="MinWidth" Value="86" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="TextBlock.brandTitle">
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style Selector="TextBlock.heroText">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="#6B7280" />
    </Style>

    <Style Selector="TextBlock.panelKicker">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#9CA3AF" />
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style Selector="TextBlock.cardTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="#6B7280" />
    </Style>

    <Style Selector="TextBlock.metricValue">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#059669" />
    </Style>

    <Style Selector="TextBlock.subtle">
      <Setter Property="Foreground" Value="#6B7280" />
    </Style>

    <Style Selector="TextBlock.viewportMuted">
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>

    <Style Selector="TextBlock.flyoutTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#111827" />
    </Style>

    <Style Selector="TextBlock.flyoutHint">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="Foreground" Value="#6B7280" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Slider">
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style Selector="Button.chromeAction">
      <Setter Property="Focusable" Value="False" />
    </Style>

    <Style Selector="CheckBox.viewerToggle">
      <Setter Property="Focusable" Value="False" />
    </Style>

    <Style Selector="Slider.viewerSlider">
      <Setter Property="Focusable" Value="False" />
    </Style>
  </Window.Styles>

  <Grid Margin="{Binding MainShellMargin}" RowDefinitions="Auto,*,Auto">
    <Border Classes="panel" Padding="4">
      <Grid ColumnDefinitions="Auto,Auto,*">
        <Border Classes="metric" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center">
          <TextBlock Classes="metricValue" Text="{Binding FilteredImageCountText}" />
        </Border>

        <CheckBox
            Classes="viewerToggle"
            Grid.Column="1"
            Margin="4,0,10,0"
            Content="包含子文件夹"
            IsChecked="{Binding IncludeSubfolders}"
            IsVisible="{Binding ShowHeaderSubfolderToggle}"
            VerticalAlignment="Center" />

        <WrapPanel Grid.Column="2" HorizontalAlignment="Right" ItemHeight="30" Orientation="Horizontal">
          <Button Classes="compact chromeAction" MinWidth="76" Margin="0,0,6,0" Content="快捷设置">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <Border Classes="quickSettings" Padding="16" MinWidth="480" MaxWidth="560">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Spacing="3">
                        <TextBlock Classes="flyoutTitle" Text="快捷设置" />
                        <TextBlock Classes="flyoutHint" Text="显示面板、快速载入和切换查看模式。" />
                      </StackPanel>
                      <Border Grid.Column="1" Padding="10,5" Background="#ECFDF5" BorderBrush="#00000000" BorderThickness="1" CornerRadius="999" VerticalAlignment="Center">
                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#059669" Text="{Binding FilteredImageCountText}" />
                      </Border>
                    </Grid>

                    <Border Classes="quickSettingsSurface" Padding="12">
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                          <CheckBox Classes="viewerToggle" Content="左侧缩略图" IsChecked="{Binding IsSidebarVisible}" />
                          <CheckBox Classes="viewerToggle" Grid.Column="1" Margin="14,0,0,0" Content="底部胶片栏" IsChecked="{Binding IsFilmstripVisible}" IsEnabled="{Binding CanToggleFilmstrip}" />
                          <CheckBox Classes="viewerToggle" Grid.Row="1" Margin="0,10,0,0" Content="图片信息" IsChecked="{Binding IsInspectorVisible}" />
                          <CheckBox Classes="viewerToggle" Grid.Row="1" Grid.Column="1" Margin="14,10,0,0" Content="包含子文件夹" IsChecked="{Binding IncludeSubfolders}" />
                        </Grid>
                      </Border>

                    <WrapPanel Orientation="Horizontal" ItemWidth="118" ItemHeight="36">
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Theme="{DynamicResource SolidButton}" Content="打开文件夹" Click="OpenFolderButton_OnClick" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="打开图片" Click="OpenFilesButton_OnClick" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="重新读取" Click="ReloadButton_OnClick" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="沉浸模式" Click="ToggleImmersiveModeButton_OnClick" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="{Binding ContactSheetToggleText}" Click="ToggleContactSheetButton_OnClick" IsEnabled="{Binding CanToggleContactSheet}" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="{Binding CompareViewerToggleText}" Click="ToggleCompareViewerButton_OnClick" IsEnabled="{Binding CanToggleCompareViewer}" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="工具箱" Click="OpenToolboxButton_OnClick" />
                      <Button Width="110" Margin="0,0,8,8" Classes="flyoutAction chromeAction" Content="所在文件夹" Click="OpenContainingFolderButton_OnClick" IsEnabled="{Binding CanOpenContainingFolder}" />
                    </WrapPanel>
                  </StackPanel>
                </Border>
              </Flyout>
            </Button.Flyout>
          </Button>
          <Button Classes="compact chromeAction" MinWidth="60" Margin="0,0,6,0" Content="工具箱" Click="OpenToolboxButton_OnClick" />
          <Button IsVisible="{Binding ShowFullHeaderActions}" Classes="compact chromeAction" MinWidth="60" Margin="0,0,6,0" Content="沉浸" Click="ToggleImmersiveModeButton_OnClick" />
          <Button Classes="compact chromeAction" Theme="{DynamicResource SolidButton}" MinWidth="86" Margin="0,0,6,0" Content="打开文件夹" Click="OpenFolderButton_OnClick" />
          <Button IsVisible="{Binding ShowFullHeaderActions}" Classes="compact chromeAction" MinWidth="76" Margin="0,0,6,0" Content="打开图片" Click="OpenFilesButton_OnClick" />
          <Button IsVisible="{Binding ShowFullHeaderActions}" Classes="compact chromeAction" MinWidth="68" Margin="0" Content="重新读取" Click="ReloadButton_OnClick" />
        </WrapPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,6,0,0" HorizontalAlignment="Stretch">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
        <ColumnDefinition Width="{Binding SidebarGapColumnWidth}" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="{Binding InspectorSpacerColumnWidth}" />
        <ColumnDefinition Width="{Binding InspectorColumnWidth}" />
      </Grid.ColumnDefinitions>

      <Border Classes="panel" Padding="0" IsVisible="{Binding ShowSidebarInMain}">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="10">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="sectionTitle" Text="缩略图" />
                <TextBlock Grid.Column="1" Classes="label" Text="{Binding FilteredImageCountText}" />
              </Grid>

              <Border Classes="section" Padding="10">
                <StackPanel Spacing="10">
                  <TextBox
                      Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                      Watermark="搜索文件名或路径" />

                  <Grid ColumnDefinitions="*,Auto">
                    <ComboBox ItemsSource="{Binding SortModes}" SelectedItem="{Binding SelectedSortMode}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Classes="compact"
                        Content="清空"
                        Click="ClearFiltersButton_OnClick"
                        IsEnabled="{Binding CanClearFilters}" />
                  </Grid>

                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                    <ComboBox ItemsSource="{Binding FormatFilterOptions}" SelectedItem="{Binding SelectedFormatFilter}" />
                    <ComboBox Grid.Column="1" Margin="8,0,0,0" ItemsSource="{Binding SizeFilterOptions}" SelectedItem="{Binding SelectedSizeFilter}" />
                    <ComboBox Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding ReviewFilterOptions}" SelectedItem="{Binding SelectedReviewFilter}" />
                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="8,8,0,0" ItemsSource="{Binding RatingFilterOptions}" SelectedItem="{Binding SelectedRatingFilter}" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <ListBox
              x:Name="ThumbnailListBox"
              Grid.Row="1"
              Margin="8"
              ItemsSource="{Binding Images}"
              SelectedItem="{Binding SelectedImage}"
              SelectionMode="Multiple"
              SelectionChanged="ThumbnailListBox_OnSelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="listItem" Padding="8">
                  <Grid ColumnDefinitions="48,*,Auto">
                    <Border
                        Width="48"
                        Height="48"
                        CornerRadius="8"
                        Background="#F3F4F6"
                        ClipToBounds="True">
                      <Grid>
                        <Image IsVisible="{Binding HasThumbnail}" Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                        <StackPanel
                            IsVisible="{Binding ShowThumbnailPlaceholder}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="2">
                          <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Text="{Binding ThumbnailPlaceholderText}" />
                        </StackPanel>
                      </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="4" VerticalAlignment="Center">
                      <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                      <TextBlock Classes="label" Text="{Binding PathText}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="8,0,0,0" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                      <TextBlock HorizontalAlignment="Right" Classes="label" Text="{Binding SizeText}" />
                      <TextBlock
                          IsVisible="{Binding HasRating}"
                          HorizontalAlignment="Right"
                          Classes="label"
                          Text="{Binding StarRatingText}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
        <Border Classes="panel" Padding="5" HorizontalAlignment="Stretch">
          <WrapPanel ItemHeight="32">
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="上一张" Click="PreviousImageButton_OnClick" IsEnabled="{Binding CanNavigateImages}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="下一张" Click="NextImageButton_OnClick" IsEnabled="{Binding CanNavigateImages}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="适应" Click="PreviewFitModeButton_OnClick" IsEnabled="{Binding CanUsePreviewFitMode}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="100%" Click="PreviewActualSizeButton_OnClick" IsEnabled="{Binding CanUsePreviewActualSize}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="{Binding LongImageModeButtonText}" Click="ToggleLongImageModeButton_OnClick" IsVisible="{Binding ShowLongImageModeButton}" IsEnabled="{Binding CanToggleLongImageMode}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="左转" Click="RotatePreviewLeftButton_OnClick" IsEnabled="{Binding CanAdjustPreview}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="右转" Click="RotatePreviewRightButton_OnClick" IsEnabled="{Binding CanAdjustPreview}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="镜像" Click="FlipPreviewButton_OnClick" IsEnabled="{Binding CanAdjustPreview}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="复位" Click="ResetPreviewToolsButton_OnClick" IsEnabled="{Binding CanResetPreviewTools}" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="沉浸" Click="ToggleImmersiveModeButton_OnClick" />
            <Button Classes="toolbar chromeAction" Margin="0,0,4,0" Content="{Binding SlideshowToggleText}" Click="ToggleSlideshowButton_OnClick" IsEnabled="{Binding CanStartSlideshow}" />
            <Button Classes="toolbar chromeAction" Content="所在文件夹" Click="OpenContainingFolderButton_OnClick" IsEnabled="{Binding CanOpenContainingFolder}" />
            <Button Classes="toolbar chromeAction" Margin="4,0,0,0" Content="回收站" Click="RecycleToTrashButton_OnClick" IsEnabled="{Binding CanRecycleToTrash}" />
          </WrapPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,4,0,0" Classes="panel" Padding="4" MinHeight="{Binding PreviewPanelMinHeight}" HorizontalAlignment="Stretch">
          <Grid RowDefinitions="*,Auto">
            <Border
                Grid.Row="0"
                Classes="viewport"
                Padding="10"
                ClipToBounds="True"
                SizeChanged="SelectedPreviewHost_OnSizeChanged">
              <Grid>
                <Grid IsVisible="{Binding ShowSinglePreviewSurface}">
                  <ScrollViewer
                     x:Name="SelectedPreviewScrollViewer"
                     Focusable="True"
                     IsVisible="{Binding HasSelectedPreview}"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                    PointerPressed="SelectedPreviewScrollViewer_OnPointerPressed"
                    PointerMoved="SelectedPreviewScrollViewer_OnPointerMoved"
                    PointerReleased="SelectedPreviewScrollViewer_OnPointerReleased"
                    PointerWheelChanged="SelectedPreviewScrollViewer_OnPointerWheelChanged">
                  <Grid
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Width="{Binding SelectedPreviewDisplayWidth}"
                      Height="{Binding SelectedPreviewDisplayHeight}">
                    <Image
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="{Binding SelectedPreviewBitmap}"
                        Width="{Binding SelectedPreviewImageDisplayWidth}"
                        Height="{Binding SelectedPreviewImageDisplayHeight}"
                        Stretch="Fill"
                        RenderTransformOrigin="0.5,0.5"
                        DoubleTapped="SelectedPreviewImage_OnDoubleTapped">
                      <Image.RenderTransform>
                        <TransformGroup>
                          <ScaleTransform ScaleX="{Binding PreviewScaleX}" ScaleY="{Binding PreviewScaleY}" />
                          <RotateTransform Angle="{Binding PreviewRotationDegrees}" />
                        </TransformGroup>
                      </Image.RenderTransform>
                    </Image>
                  </Grid>
                </ScrollViewer>

                <StackPanel
                    IsVisible="{Binding ShowSelectedPreviewPlaceholder}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="460"
                    Spacing="10">
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Button Theme="{DynamicResource SolidButton}" MinWidth="104" Content="打开图片" Click="OpenFilesButton_OnClick" />
                    <Button  MinWidth="104" Content="打开文件夹" Click="OpenFolderButton_OnClick" />
                  </StackPanel>
                  <TextBlock
                      HorizontalAlignment="Center"
                      Classes="viewportMuted"
                      Text="{Binding SupportedFormatsText}"
                      TextAlignment="Center"
                      TextWrapping="Wrap" />
                </StackPanel>

                </Grid>

                <Grid IsVisible="{Binding ShowContactSheetViewer}" RowDefinitions="Auto,*">
                  <Grid ColumnDefinitions="*,Auto" Margin="4,4,4,12">
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FFFFFF" Text="联系表" />
                      <TextBlock Classes="viewportMuted" Text="{Binding ContactSheetSummaryText}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="compact" Content="{Binding ContactSheetToggleText}" Click="ToggleContactSheetButton_OnClick" />
                  </Grid>

                  <ScrollViewer
                      x:Name="ContactSheetViewport"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Loaded="ContactSheetViewport_OnLoaded"
                      SizeChanged="ContactSheetViewport_OnSizeChanged">
                    <StackPanel Spacing="10">
                      <TextBlock
                          IsVisible="{Binding ShowContactSheetEmptyState}"
                          Margin="0,32,0,0"
                          HorizontalAlignment="Center"
                          MaxWidth="560"
                          Classes="viewportMuted"
                          Text="{Binding ContactSheetEmptyText}"
                          TextAlignment="Center"
                          TextWrapping="Wrap" />
                      <ItemsControl IsVisible="{Binding HasContactSheetItems}" ItemsSource="{Binding ContactSheetItems}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Button
                                Margin="0,0,12,12"
                                Padding="0"
                                Width="{Binding DataContext.ContactSheetTileWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Click="FocusContactSheetImageButton_OnClick">
                              <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel Spacing="10">
                                  <Border
                                      Height="{Binding DataContext.ContactSheetTileHeight, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                      Classes="viewport"
                                      ClipToBounds="True">
                                    <Grid>
                                      <Image IsVisible="{Binding HasThumbnail}" Source="{Binding Thumbnail}" Stretch="Uniform" />
                                      <StackPanel
                                          IsVisible="{Binding ShowThumbnailPlaceholder}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Spacing="2">
                                        <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#FFFFFF" Text="{Binding ThumbnailPlaceholderText}" />
                                        <TextBlock HorizontalAlignment="Center" Classes="viewportMuted" FontSize="11" Text="{Binding ThumbnailHintText}" />
                                      </StackPanel>
                                    </Grid>
                                  </Border>
                                  <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                  <TextBlock Classes="label" Text="{Binding SizeText}" />
                                </StackPanel>
                              </Border>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding ShowCompareViewerSurface}" RowDefinitions="Auto,*">
                  <Border Classes="toolbarSurface" Padding="12" Margin="4,4,4,12">
                    <StackPanel Spacing="10">
                      <TextBlock Classes="label" Text="{Binding CompareSummaryText}" TextWrapping="Wrap" />
                      <Grid ColumnDefinitions="*,*,*">
                        <Button Content="{Binding AddCurrentToCompareActionText}" Click="AddCurrentToCompareButton_OnClick" IsEnabled="{Binding CanAddCurrentToCompare}" />
                        <Button Grid.Column="1" Margin="8,0,0,0" Content="移除当前图" Click="RemoveCurrentFromCompareButton_OnClick" IsEnabled="{Binding CanRemoveCurrentFromCompare}" />
                        <Button Grid.Column="2" Margin="8,0,0,0" Content="清空对比区" Click="ClearCompareButton_OnClick" IsEnabled="{Binding CanClearCompare}" />
                      </Grid>
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock VerticalAlignment="Center" Classes="label" Text="统一缩放" />
                        <Slider Classes="viewerSlider" Grid.Column="1" Margin="12,0,12,0" Minimum="25" Maximum="300" Value="{Binding CompareZoomPercent, Mode=TwoWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding CompareZoomText}" />
                      </Grid>
                    </StackPanel>
                  </Border>

                  <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                      <TextBlock
                          IsVisible="{Binding ShowCompareEmptyState}"
                          Margin="0,32,0,0"
                          HorizontalAlignment="Center"
                          MaxWidth="520"
                          Classes="viewportMuted"
                          Text="{Binding CompareEmptyText}"
                          TextAlignment="Center"
                          TextWrapping="Wrap" />
                      <ItemsControl IsVisible="{Binding HasCompareItems}" ItemsSource="{Binding CompareItems}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Width="360" Margin="0,0,12,12" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="12">
                              <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                  <Border Padding="8,4" CornerRadius="6" Background="#ECFDF5">
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#059669" Text="{Binding RoleLabel}" />
                                  </Border>
                                  <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                  <Button Grid.Column="2" Margin="8,0,0,0" Classes="compact" Content="设为主图" Click="PromoteCompareItemButton_OnClick" IsEnabled="{Binding CanPromote}" />
                                  <Button Grid.Column="3" Margin="8,0,0,0" Classes="compact" Content="移除" Click="RemoveCompareItemButton_OnClick" />
                                </Grid>
                                <Border Height="260" Classes="viewport" Padding="12">
                                  <Grid>
                                    <ScrollViewer
                                        IsVisible="{Binding HasPreview}"
                                        Loaded="ComparePaneScrollViewer_OnLoaded"
                                        Unloaded="ComparePaneScrollViewer_OnUnloaded"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto"
                                        PointerPressed="ComparePaneScrollViewer_OnPointerPressed"
                                        PointerWheelChanged="ComparePaneScrollViewer_OnPointerWheelChanged"
                                        ScrollChanged="ComparePaneScrollViewer_OnScrollChanged">
                                      <Image
                                          Source="{Binding PreviewBitmap}"
                                          Width="{Binding DisplayWidth}"
                                          Height="{Binding DisplayHeight}"
                                          Stretch="Fill" />
                                    </ScrollViewer>
                                    <StackPanel
                                        IsVisible="{Binding ShowPreviewPlaceholder}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="220"
                                        Spacing="6">
                                      <TextBlock
                                          HorizontalAlignment="Center"
                                          FontSize="16"
                                          FontWeight="SemiBold"
                                          Foreground="#FFFFFF"
                                          Text="{Binding StatusText}"
                                          TextAlignment="Center"
                                          TextWrapping="Wrap" />
                                      <TextBlock
                                          HorizontalAlignment="Center"
                                          Classes="viewportMuted"
                                          Text="{Binding DetailsText}"
                                          TextAlignment="Center"
                                          TextWrapping="Wrap" />
                                    </StackPanel>
                                  </Grid>
                                </Border>
                                <TextBlock Classes="label" Text="{Binding DetailsText}" TextWrapping="Wrap" />
                                <TextBlock Classes="label" Text="{Binding FolderPath}" TextTrimming="CharacterEllipsis" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </Grid>
              </Grid>
              </Border>

            <Border Grid.Row="1" Classes="toolbarSurface" Padding="8,6" IsVisible="{Binding ShowSinglePreviewSurface}">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock VerticalAlignment="Center" Classes="label" Text="缩放" />
                <Slider Classes="viewerSlider" Grid.Column="1" Margin="12,0,12,0" Minimum="25" Maximum="300" Value="{Binding PreviewZoomPercent, Mode=TwoWay}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding PreviewZoomText}" />
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="2" Classes="panel" Padding="6" IsVisible="{Binding ShowFilmstripInMain}">
          <Grid>
            <ListBox
                x:Name="FilmstripListBox"
                Height="{Binding FilmstripHeight}"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding Images}"
                SelectedItem="{Binding SelectedImage}"
                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                ScrollViewer.VerticalScrollBarVisibility="Disabled">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Margin" Value="0,0,10,0" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Width="{Binding DataContext.FilmstripItemWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" Classes="listItem" Padding="8">
                    <StackPanel Spacing="6">
                      <Border Height="{Binding DataContext.FilmstripThumbnailHeight, RelativeSource={RelativeSource AncestorType=ListBox}}" Classes="viewport" ClipToBounds="True">
                        <Grid>
                          <Image IsVisible="{Binding HasThumbnail}" Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                          <StackPanel
                              IsVisible="{Binding ShowThumbnailPlaceholder}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Spacing="2">
                            <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#FFFFFF" Text="{Binding ThumbnailPlaceholderText}" />
                            <TextBlock HorizontalAlignment="Center" Classes="viewportMuted" FontSize="11" Text="{Binding ThumbnailHintText}" />
                          </StackPanel>
                        </Grid>
                      </Border>
                      <TextBlock FontWeight="SemiBold" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="4" Classes="panel" Padding="12" IsVisible="{Binding ShowInspectorInMain}">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Spacing="4">
            <TextBlock Classes="sectionTitle" Text="图片信息" />
          </StackPanel>

          <ScrollViewer Grid.Row="1" Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
              <Border Classes="section" Padding="10">
                <StackPanel Spacing="10">
                  <TextBlock Classes="panelKicker" Text="当前文件" />
                  <TextBlock Classes="cardTitle" Text="{Binding SelectedFileNameText}" TextWrapping="Wrap" />
                  <TextBlock Classes="label" Text="{Binding SelectedPathText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <Border Classes="section" Padding="10">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                  <StackPanel Margin="0,0,6,8" Spacing="4">
                    <TextBlock Classes="panelKicker" Text="尺寸" />
                    <TextBlock Text="{Binding SelectedDimensionsText}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Margin="6,0,0,8" Spacing="4">
                    <TextBlock Classes="panelKicker" Text="大小 / 时间" />
                    <TextBlock Classes="label" Text="{Binding SelectedMetaText}" TextWrapping="Wrap" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Margin="0,0,6,8" Spacing="4">
                    <TextBlock Classes="panelKicker" Text="格式" />
                    <TextBlock Text="{Binding SelectedFormatText}" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,8" Spacing="4">
                    <TextBlock Classes="panelKicker" Text="浏览方式" />
                    <TextBlock Text="{Binding InspectorModeText}" />
                  </StackPanel>
                  <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="4">
                    <TextBlock Classes="panelKicker" Text="所在文件夹" />
                    <TextBlock Classes="label" Text="{Binding SelectedFolderText}" TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>
              </Border>

              <Border Classes="section" Padding="10">
                <StackPanel Spacing="10">
                  <TextBlock Classes="panelKicker" Text="拍摄信息" />
                  <TextBlock
                      IsVisible="{Binding ShowSelectedExifHint}"
                      Classes="label"
                      Text="{Binding SelectedExifStatusText}"
                      TextWrapping="Wrap" />
                    <ItemsControl IsVisible="{Binding HasSelectedExifItems}" HorizontalAlignment="Left" ItemsSource="{Binding SelectedExifItems}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Grid ColumnDefinitions="96,Auto" Margin="0,0,0,8">
                            <TextBlock
                                Margin="0,2,12,0"
                                Classes="panelKicker"
                                Text="{Binding Label}"
                                TextWrapping="NoWrap" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="160"
                                FontSize="12.5"
                                Text="{Binding Value}"
                                TextWrapping="NoWrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

              <Border Classes="section" Padding="10">
                <StackPanel Spacing="10">
                  <TextBlock Classes="panelKicker" Text="筛图状态" />
                  <TextBlock Classes="label" Text="{Binding CurrentImageReviewText}" TextWrapping="Wrap" />
                  <TextBlock Classes="label" Text="{Binding CurrentImagePositionText}" />
                  <TextBlock Classes="label" Text="{Binding CurrentImageNavigationHintText}" TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <WrapPanel>
                <Button Classes="compact" Margin="0,0,10,10" Content="复制路径" Click="CopyPathButton_OnClick" IsEnabled="{Binding CanCopyOperationPaths}" />
                <Button Classes="compact" Margin="0,0,10,10" Content="打开所在文件夹" Click="OpenContainingFolderButton_OnClick" IsEnabled="{Binding CanOpenContainingFolder}" />
                <Button Classes="compact" Margin="0,0,0,10" Content="{Binding RecycleToTrashActionText}" Click="RecycleToTrashButton_OnClick" IsEnabled="{Binding CanRecycleToTrash}" />
              </WrapPanel>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Classes="panel" Padding="6" Margin="0,6,0,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
        <Button Classes="compact" Content="{Binding SlideshowToggleText}" Click="ToggleSlideshowButton_OnClick" IsEnabled="{Binding CanStartSlideshow}" />
        <Border Grid.Column="1" Margin="8,0,0,0" Classes="metric" Padding="12,5" VerticalAlignment="Center">
          <TextBlock Classes="metricValue" Text="{Binding CurrentImagePositionText}" />
        </Border>
        <Border Grid.Column="2" Margin="8,0,0,0" Classes="metric" Padding="12,5" VerticalAlignment="Center">
          <TextBlock Classes="metricValue" Text="{Binding PreviewZoomText}" />
        </Border>
        <TextBlock Grid.Column="3" />
        <WrapPanel Grid.Column="4" IsVisible="{Binding ShowFooterActions}">
          <Button Classes="compact chromeAction" Margin="0,0,6,0" Content="打开所在文件夹" Click="OpenContainingFolderButton_OnClick" IsEnabled="{Binding CanOpenContainingFolder}" />
          <Button Classes="compact chromeAction" Content="{Binding RecycleToTrashActionText}" Click="RecycleToTrashButton_OnClick" IsEnabled="{Binding CanRecycleToTrash}" />
        </WrapPanel>
      </Grid>
    </Border>

  </Grid>
</Window>


